generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ───────────────────────────────────────────────

enum UserRole {
  admin
  client
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  role         UserRole @default(client)
  active       Boolean  @default(true)
  passwordHash String?  @map("password_hash")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sessions     Session[]
  magicLinks   MagicLink[]
  contacts     Contact[]    @relation("ContactUser")
  documents    Document[]   @relation("UploadedBy")
  appointments Appointment[]

  @@map("users")
}

model MagicLink {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")
  user      User?     @relation(fields: [userId], references: [id])
  userId    String?   @map("user_id")

  @@map("magic_links")
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ─── Clients / Prospects ────────────────────────────────

enum ContactType {
  prospect
  client
  ancien
}

model Contact {
  id          String      @id @default(cuid())
  userId      String?     @unique @map("user_id")
  type        ContactType @default(prospect)
  companyName String?     @map("company_name")
  firstName   String      @map("first_name")
  lastName    String      @map("last_name")
  email       String?
  phone       String?
  address     String?
  city        String?
  country     String?     @default("Luxembourg")
  notes       String?
  source      String?
  waId        String?     @map("wa_id")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  user         User?        @relation("ContactUser", fields: [userId], references: [id])
  quotes       Quote[]
  invoices     Invoice[]
  dossiers     Dossier[]
  documents    Document[]
  appointments Appointment[]
  messages     Message[]
  lead         Lead?

  @@map("contacts")
}

// ─── Devis & Facturation ────────────────────────────────

enum QuoteStatus {
  draft
  sent
  accepted
  rejected
  expired
}

model Quote {
  id        String      @id @default(cuid())
  contactId String      @map("contact_id")
  number    String      @unique
  status    QuoteStatus @default(draft)
  items     Json
  subtotal  Decimal     @db.Decimal(10, 2)
  taxRate   Decimal     @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount Decimal     @default(0) @map("tax_amount") @db.Decimal(10, 2)
  total     Decimal     @db.Decimal(10, 2)
  validUntil DateTime?  @map("valid_until")
  notes     String?
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  contact  Contact   @relation(fields: [contactId], references: [id])
  invoices Invoice[]

  @@map("quotes")
}

enum InvoiceStatus {
  draft
  sent
  paid
  overdue
  cancelled
}

model Invoice {
  id            String        @id @default(cuid())
  contactId     String        @map("contact_id")
  quoteId       String?       @map("quote_id")
  number        String        @unique
  status        InvoiceStatus @default(draft)
  items         Json
  subtotal      Decimal       @db.Decimal(10, 2)
  taxRate       Decimal       @default(0) @map("tax_rate") @db.Decimal(5, 2)
  taxAmount     Decimal       @default(0) @map("tax_amount") @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  dueDate       DateTime?     @map("due_date")
  paidAt        DateTime?     @map("paid_at")
  paymentMethod String?       @map("payment_method")
  notes         String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  contact Contact @relation(fields: [contactId], references: [id])
  quote   Quote?  @relation(fields: [quoteId], references: [id])

  @@map("invoices")
}

// ─── Dossiers Fiscaux ───────────────────────────────────

enum DossierType {
  tva_mensuelle
  ir
  is
  comptabilite
  ccss
  coordination
}

enum DossierStatus {
  todo
  docs_pending
  in_progress
  review
  done
}

model Dossier {
  id        String        @id @default(cuid())
  contactId String        @map("contact_id")
  type      DossierType
  year      Int
  period    String?
  status    DossierStatus @default(todo)
  deadline  DateTime?
  checklist Json?
  notes     String?
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  contact   Contact    @relation(fields: [contactId], references: [id])
  documents Document[]

  @@map("dossiers")
}

model Document {
  id         String   @id @default(cuid())
  dossierId  String?  @map("dossier_id")
  contactId  String   @map("contact_id")
  name       String
  path       String
  mimeType   String?  @map("mime_type")
  size       Int?
  uploadedBy String   @map("uploaded_by")
  createdAt  DateTime @default(now()) @map("created_at")

  dossier  Dossier? @relation(fields: [dossierId], references: [id])
  contact  Contact  @relation(fields: [contactId], references: [id])
  uploader User     @relation("UploadedBy", fields: [uploadedBy], references: [id])

  @@map("documents")
}

// ─── Agenda ─────────────────────────────────────────────

enum AppointmentType {
  consultation
  suivi
  admin
}

enum AppointmentStatus {
  scheduled
  done
  cancelled
}

model Appointment {
  id          String            @id @default(cuid())
  contactId   String?           @map("contact_id")
  supplierId  String?           @map("supplier_id")
  userId      String?           @map("user_id")
  title       String
  description String?
  startAt     DateTime          @map("start_at")
  endAt       DateTime          @map("end_at")
  location    String?
  type        AppointmentType   @default(consultation)
  status      AppointmentStatus @default(scheduled)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  contact  Contact?  @relation(fields: [contactId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])
  user     User?     @relation(fields: [userId], references: [id])

  @@map("appointments")
}

// ─── Inbox ──────────────────────────────────────────────

enum MessageChannel {
  whatsapp
  email
}

enum MessageDirection {
  in
  out
}

model Message {
  id        String           @id @default(cuid())
  contactId String?          @map("contact_id")
  leadId    String?          @map("lead_id")
  channel   MessageChannel
  direction MessageDirection
  fromAddr  String?          @map("from_addr")
  toAddr    String?          @map("to_addr")
  subject   String?
  body      String
  rawData   Json?            @map("raw_data")
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at")

  contact Contact? @relation(fields: [contactId], references: [id])
  lead    Lead?    @relation(fields: [leadId], references: [id])

  @@map("messages")
}

// ─── Leads / Prospection ────────────────────────────────

enum LeadStatus {
  new
  contacted
  replied
  qualified
  lost
  converted
}

enum OutreachChannel {
  email
  whatsapp
  sms
}

enum OutreachStatus {
  draft
  sent
  replied
  bounced
}

model Lead {
  id              String     @id @default(cuid())
  displayName     String     @map("salon_name")
  activityType    String?    @map("activity_type")
  leadType        String     @default("business") @map("lead_type")
  address         String?
  phone           String?
  phones          Json?
  email           String?
  emails          Json?
  ownerName       String?    @map("owner_name")
  ownerTitle      String?    @map("owner_title")
  ownerConfidence String?    @map("owner_confidence")
  ownerSource     String?    @map("owner_source")
  rcsNumber       String?    @map("rcs_number")
  linkedinUrl     String?    @map("linkedin_url")
  enrichNotes     String?    @map("enrich_notes")
  websiteUrl      String?    @map("website_url")
  source          String     @default("salonkee")
  sourceUrl       String?    @map("source_url")
  reviewsCount    Int?       @map("reviews_count")
  status          LeadStatus @default(new)
  notes           String?
  contactId       String?    @unique @map("contact_id")
  convertedAt     DateTime?  @map("converted_at")
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  // Forum / annonce fields
  forumUsername    String?    @map("forum_username")
  topicTitle      String?    @map("topic_title")
  topicUrl        String?    @map("topic_url")
  topicCategory   String?    @map("topic_category")
  topicDate       DateTime?  @map("topic_date")
  replyCount      Int?       @map("reply_count")
  viewCount       Int?       @map("view_count")
  aiSummary       String?    @map("ai_summary")

  importBatch String?    @map("import_batch")

  contact    Contact?    @relation(fields: [contactId], references: [id])
  outreaches Outreach[]
  labels     LeadLabel[]
  messages   Message[]

  @@unique([displayName, address], name: "lead_identity")
  @@map("leads")
}

model Label {
  id        String      @id @default(cuid())
  name      String      @unique
  color     String      @default("#6b7280")
  createdAt DateTime    @default(now()) @map("created_at")

  leads LeadLabel[]

  @@map("labels")
}

model LeadLabel {
  leadId  String @map("lead_id")
  labelId String @map("label_id")

  lead  Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  label Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([leadId, labelId])
  @@map("lead_labels")
}

model ScrapeJob {
  id          String    @id @default(cuid())
  source      String
  config      Json
  status      String    @default("pending")
  progress    Int       @default(0)
  total       Int       @default(0)
  phase       String?
  resultCount Int?      @map("result_count")
  errorLog    String?   @map("error_log")
  startedAt   DateTime? @map("started_at")
  finishedAt  DateTime? @map("finished_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("scrape_jobs")
}

model OutreachTemplate {
  id          String          @id @default(cuid())
  name        String
  channel     OutreachChannel
  subject     String?
  body        String
  cardVersion String?         @map("card_version")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  @@map("outreach_templates")
}

model Supplier {
  id          String   @id @default(cuid())
  name        String
  contactName String?  @map("contact_name")
  role        String?
  email       String?
  phone       String?
  website     String?
  address     String?
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  appointments Appointment[]

  @@map("suppliers")
}

model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

model Outreach {
  id         String          @id @default(cuid())
  leadId     String          @map("lead_id")
  channel    OutreachChannel
  status     OutreachStatus  @default(draft)
  subject    String?
  body       String
  templateId String?         @map("template_id")
  sentAt     DateTime?       @map("sent_at")
  repliedAt  DateTime?       @map("replied_at")
  notes      String?
  createdAt  DateTime        @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("outreaches")
}
